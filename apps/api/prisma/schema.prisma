// ============================================================================
// Ayrton SaaS Platform — Multi-tenant schema
// Estrategia: single database, single schema, aislamiento por tenant_id +
// Postgres Row Level Security (RLS) aplicado en migración SQL adicional.
// Permite miles de tenants sin overhead de crear schema/DB por cliente.
// ============================================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
  binaryTargets   = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

// ---------------------------------------------------------------------------
// TENANCY & AUTH
// ---------------------------------------------------------------------------

enum PlanTier {
  TRIAL
  STARTER
  PRO
  SCALE
}

model Tenant {
  id          String   @id @default(uuid())
  slug        String   @unique // ej: "ayrton-estilistas"
  name        String
  timezone    String   @default("America/Argentina/Cordoba")
  locale      String   @default("es-AR")
  plan        PlanTier @default(TRIAL)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users           User[]
  employees       Employee[]
  services        Service[]
  customers       Customer[]
  appointments    Appointment[]
  conversations   Conversation[]
  agentConfig     AgentConfig?
  knowledgeDocs   KnowledgeDocument[]
  channels        ChannelConnection[]
  reminders       Reminder[]
  promotions      Promotion[]
  reviewRequests  ReviewRequest[]
  businessProfile BusinessProfile?

  @@map("tenants")
}

model BusinessProfile {
  id          String  @id @default(uuid())
  tenantId    String  @unique
  tenant      Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  legalName   String?
  address     String?
  city        String?
  country     String  @default("AR")
  phone       String?
  email       String?
  logoUrl     String?
  primaryColor String? @default("#111827")
  description String?
  socialLinks Json?   // { instagram, facebook, website }
  businessHours Json? // { mon: [["09:00","13:00"],["16:00","20:00"]], ... }

  @@map("business_profiles")
}

enum UserRole {
  OWNER
  ADMIN
  STAFF
  AGENT_SUPERVISOR
}

model User {
  id           String   @id @default(uuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email        String
  passwordHash String
  fullName     String
  role         UserRole @default(STAFF)
  isActive     Boolean  @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

// ---------------------------------------------------------------------------
// CATALOGO: EMPLEADOS Y SERVICIOS
// ---------------------------------------------------------------------------

model Employee {
  id         String   @id @default(uuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  fullName   String
  photoUrl   String?
  isActive   Boolean  @default(true)
  workingHours Json?  // horario semanal específico del empleado
  services   EmployeeService[]
  appointments Appointment[]
  createdAt  DateTime @default(now())

  @@index([tenantId])
  @@map("employees")
}

model Service {
  id           String   @id @default(uuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name         String
  description  String?
  durationMin  Int
  priceCents   Int
  currency     String   @default("ARS")
  isActive     Boolean  @default(true)
  employees    EmployeeService[]
  appointments Appointment[]
  createdAt    DateTime @default(now())

  @@index([tenantId])
  @@map("services")
}

model EmployeeService {
  employeeId String
  serviceId  String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  service    Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([employeeId, serviceId])
  @@map("employee_services")
}

// ---------------------------------------------------------------------------
// CRM: CLIENTES
// ---------------------------------------------------------------------------

model Customer {
  id           String   @id @default(uuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  fullName     String?
  phone        String?
  email        String?
  passwordHash String?  // seteado solo si el cliente se registró para tener cuenta propia
  notes        String?
  tags         String[] @default([])
  totalVisits  Int      @default(0)
  lastVisitAt  DateTime?
  createdAt    DateTime @default(now())

  appointments   Appointment[]
  conversations  Conversation[]
  reviewRequests ReviewRequest[]

  @@unique([tenantId, phone])
  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("customers")
}

// ---------------------------------------------------------------------------
// TURNOS
// ---------------------------------------------------------------------------

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

model Appointment {
  id         String            @id @default(uuid())
  tenantId   String
  tenant     Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customerId String
  customer   Customer          @relation(fields: [customerId], references: [id])
  employeeId String
  employee   Employee          @relation(fields: [employeeId], references: [id])
  serviceId  String
  service    Service           @relation(fields: [serviceId], references: [id])
  startsAt   DateTime
  endsAt     DateTime
  status     AppointmentStatus @default(PENDING)
  source     String            @default("agent") // agent | dashboard | web
  notes      String?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  @@index([tenantId, employeeId, startsAt])
  @@index([tenantId, status])
  @@map("appointments")
}

// ---------------------------------------------------------------------------
// CONVERSACIONES / MENSAJERÍA OMNICANAL
// ---------------------------------------------------------------------------

enum ChannelType {
  WHATSAPP
  INSTAGRAM
  MESSENGER
  WEB
}

model ChannelConnection {
  id           String      @id @default(uuid())
  tenantId     String
  tenant       Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  channel      ChannelType
  externalId   String      // phone_number_id / page_id / ig_business_id
  accessToken  String      // cifrado a nivel de aplicación (ver EncryptionService)
  displayLabel String?     // número o @usuario visible para el cliente en el panel (no técnico)
  isActive     Boolean     @default(true)
  metadata     Json?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@unique([tenantId, channel])
  @@index([externalId])
  @@map("channel_connections")
}

enum ConversationStatus {
  OPEN
  WAITING_HUMAN
  CLOSED
}

model Conversation {
  id           String              @id @default(uuid())
  tenantId     String
  tenant       Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customerId   String?
  customer     Customer?           @relation(fields: [customerId], references: [id])
  channel      ChannelType
  externalUserId String            // wa_id / ig_user_id / psid
  status       ConversationStatus  @default(OPEN)
  handedOffToHuman Boolean         @default(false)
  lastMessageAt DateTime           @default(now())
  createdAt    DateTime            @default(now())

  messages     Message[]

  @@unique([tenantId, channel, externalUserId])
  @@index([tenantId, status])
  @@map("conversations")
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
  HUMAN_AGENT
}

model Message {
  id             String        @id @default(uuid())
  conversationId String
  conversation   Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           MessageRole
  content        String
  toolCalls      Json?
  createdAt      DateTime      @default(now())

  @@index([conversationId, createdAt])
  @@map("messages")
}

// ---------------------------------------------------------------------------
// AGENTE IA: CONFIGURACIÓN Y BASE DE CONOCIMIENTOS (RAG)
// ---------------------------------------------------------------------------

model AgentConfig {
  id              String   @id @default(uuid())
  tenantId        String   @unique
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  systemPrompt    String   @db.Text
  model           String   @default("claude-sonnet-5")
  temperature     Float    @default(0.4)
  handoffKeywords String[] @default(["hablar con una persona", "quiero un humano"])
  greetingMessage String   @default("¡Hola! Soy el asistente virtual. ¿En qué puedo ayudarte?")
  isEnabled       Boolean  @default(true)
  updatedAt       DateTime @updatedAt

  @@map("agent_configs")
}

model KnowledgeDocument {
  id         String   @id @default(uuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title      String
  sourceType String   @default("manual") // manual | faq | policy | upload
  rawContent String   @db.Text
  createdAt  DateTime @default(now())

  chunks     KnowledgeChunk[]

  @@index([tenantId])
  @@map("knowledge_documents")
}

model KnowledgeChunk {
  id          String              @id @default(uuid())
  documentId  String
  document    KnowledgeDocument   @relation(fields: [documentId], references: [id], onDelete: Cascade)
  tenantId    String              // denormalizado para filtrar RAG rápido
  content     String              @db.Text
  embedding   Unsupported("vector(1536)")?

  @@index([tenantId])
  @@map("knowledge_chunks")
}

// ---------------------------------------------------------------------------
// MARKETING: RECORDATORIOS, RESEÑAS, PROMOCIONES
// ---------------------------------------------------------------------------

enum ReminderStatus {
  SCHEDULED
  SENT
  FAILED
  CANCELLED
}

model Reminder {
  id            String         @id @default(uuid())
  tenantId      String
  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointmentId String?
  scheduledFor  DateTime
  channel       ChannelType
  status        ReminderStatus @default(SCHEDULED)
  payload       Json
  createdAt     DateTime       @default(now())

  @@index([tenantId, status, scheduledFor])
  @@map("reminders")
}

model ReviewRequest {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id])
  sentAt      DateTime?
  respondedAt DateTime?
  rating      Int?
  comment     String?
  createdAt   DateTime @default(now())

  @@map("review_requests")
}

model Promotion {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title       String
  message     String   @db.Text
  channel     ChannelType
  scheduledFor DateTime?
  sentAt      DateTime?
  audience    Json?    // filtros: tags, ultima visita, etc.
  createdAt   DateTime @default(now())

  @@map("promotions")
}
