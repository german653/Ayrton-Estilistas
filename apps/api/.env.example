# --- Base de datos ---
DATABASE_URL="postgresql://ayrton:ayrton@localhost:5432/ayrton_saas?schema=public"

# --- Redis (colas BullMQ) ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Auth ---
JWT_SECRET="cambia-este-secreto-en-produccion-por-uno-de-64-caracteres-random"

# --- Agente IA (Claude) ---
ANTHROPIC_API_KEY="sk-ant-..."

# --- Embeddings para RAG (Voyage AI) ---
VOYAGE_API_KEY="pa-..."

# --- WhatsApp Cloud API (Meta) ---
WHATSAPP_VERIFY_TOKEN="token-que-vos-elegis-para-la-verificacion-del-webhook"

# --- Messenger / Instagram (Meta Graph API) ---
META_VERIFY_TOKEN="token-que-vos-elegis-para-la-verificacion-del-webhook"

# --- Cloudinary (galería de imágenes / carrusel público) ---
CLOUDINARY_CLOUD_NAME="tu-cloud-name"
CLOUDINARY_API_KEY="tu-api-key"
CLOUDINARY_API_SECRET="tu-api-secret"

PORT=4000
